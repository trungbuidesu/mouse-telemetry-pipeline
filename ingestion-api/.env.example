# Ingestion API local environment example
# Copy to ingestion-api/.env for local overrides. Do not commit real secrets.
# Settings use prefix MOUSE_TELEMETRY_ (see app/core/config.py).

MOUSE_TELEMETRY_APP_NAME=Mouse Telemetry Ingestion API
MOUSE_TELEMETRY_ENVIRONMENT=local

# Comma-separated origins are not parsed yet; defaults live in Settings.
# When CORS parsing from env is added, use a documented format here.

# Typed Kafka settings (DEC-005). Producer service arrives in T2.5; live Kafka not required for T2.1.
MOUSE_TELEMETRY_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MOUSE_TELEMETRY_KAFKA_TOPIC=mouse.telemetry.events.v1
