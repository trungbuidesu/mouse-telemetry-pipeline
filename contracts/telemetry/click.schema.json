{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mouse-telemetry.local/contracts/telemetry/click.schema.json",
  "title": "ClickEvent",
  "type": "object",
  "required": [
    "eventId",
    "sessionId",
    "eventType",
    "eventTime",
    "sequence",
    "x",
    "y",
    "targetId",
    "targetHit",
    "reactionTimeMs"
  ],
  "properties": {
    "eventId": { "type": "string", "minLength": 1 },
    "sessionId": { "type": "string", "minLength": 1 },
    "eventType": { "const": "click" },
    "eventTime": { "type": "integer", "minimum": 0 },
    "sequence": { "type": "integer", "minimum": 0 },
    "x": { "type": "number" },
    "y": { "type": "number" },
    "normalizedX": { "type": "number", "minimum": 0, "maximum": 1 },
    "normalizedY": { "type": "number", "minimum": 0, "maximum": 1 },
    "targetId": { "type": "string", "minLength": 1 },
    "targetHit": { "type": "boolean" },
    "reactionTimeMs": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": false
}
